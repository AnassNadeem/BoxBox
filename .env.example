# Copy to .env and fill in. NEVER commit .env.
OPENROUTER_API_KEY=<your-openrouter-api-key>
# Paid model calls are only permitted when ALLOW_SPEND=1 AND a key is present.
ALLOW_SPEND=0

# OpenF1 paid subscription — OAuth2 via username+password (no API key). See https://openf1.org/auth.html
OPENF1_USERNAME=your_username
OPENF1_PASSWORD=your_password
